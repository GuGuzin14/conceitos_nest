@baseURL = http://localhost:3000

# RECADOS
### Lista todos os recados
GET {{baseURL}}/recados/
?limit=10
&offset=10

###Lista apenas um recado
GET {{baseURL}}/recados/4/

###Cria um recado
POST {{baseURL}}/recados/
Content-Type: application/json

{
    "texto": "Novo Recado",
    "de": "Joana",
    "para": "João"
  }

### Atualiza o Recado
PATCH {{baseURL}}/recados/4/
Content-Type: application/json

{
    "texto": "Recado 1",
    "lido": true
}

###Deleta um Recado
DELETE  {{baseURL}}/recados/2/


